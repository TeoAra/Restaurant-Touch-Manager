# HelloTable — configurazione locale Windows
# Copia questo file come .env nella cartella di installazione (C:\HelloTable\.env)

# ── Database PostgreSQL ──────────────────────────────────────────────────────
# Opzione A: usa il database Replit (per i test iniziali, richiede internet)
# Copia il valore da Replit → Tools → Database → Connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Opzione B: PostgreSQL locale (per uso continuativo senza internet)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/hellotable

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Frontend statico ─────────────────────────────────────────────────────────
# Percorso assoluto alla cartella del frontend compilato
LOCAL_FRONTEND_DIR=C:\HelloTable\artifacts\pos-restaurant\dist\public

# ── Sessioni ─────────────────────────────────────────────────────────────────
# Stringa casuale lunga almeno 32 caratteri
SESSION_SECRET=cambia_con_una_stringa_casuale_sicura_di_almeno_32_caratteri

# ── Stampanti fiscali (DTR / Sewoo TCP) ─────────────────────────────────────
# Configura dall'interfaccia backoffice dopo l'installazione
# PRINTER_FISCAL_IP=192.168.1.100
# PRINTER_FISCAL_PORT=9100
# PRINTER_KITCHEN_IP=192.168.1.101
# PRINTER_KITCHEN_PORT=9100
